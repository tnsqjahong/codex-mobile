{
  "name": "codex-mobile-companion",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "bin": {
    "codex-mobile": "./bin/codex-mobile.js"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite --host 127.0.0.1",
    "cli": "node bin/codex-mobile.js",
    "start": "npm run build && node bin/codex-mobile.js --background",
    "start:foreground": "npm run build && node bin/codex-mobile.js",
    "serve": "npm run build && node src/bridge/server.js",
    "doctor": "node src/bridge/doctor.js",
    "setup": "npm install && npm run doctor",
    "probe": "node src/bridge/probe.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
