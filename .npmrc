# vite-plugin-pwa@1.2.0 has not bumped its peerDependencies to include
# vite@8 yet (tracked upstream: vite-pwa/vite-plugin-pwa#923). Vite 8's
# plugin compat layer keeps the plugin functional, so we relax the
# peer-dep check at install time. Remove this line once vite-plugin-pwa
# ships a release with vite@8 in peerDependencies.
legacy-peer-deps=true
